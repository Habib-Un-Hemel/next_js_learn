generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role Role @default(USER)
  teamId Int?
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //index
    @@index([email])
    @@index([role])
    @@index([teamId])

    @@map("users")
}


model Team {
  id        Int      @id @default(autoincrement())
  name      String
    description String?
    code String @unique
    members User[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt



    @@map("teams")
} 


enum Role {
  USER
  MANAGER
  ADMIN
  GUEST
}
